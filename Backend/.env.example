# ─────────────────────────────────────────────────────────────
# NVIDIA AI API Configuration
# Get your API key from: https://build.nvidia.com/
# ─────────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NAME=meta/llama-3.1-70b-instruct
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────
# PostgreSQL Database Configuration
# Using Docker Compose: run `docker-compose up -d` first
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://recipe_user:recipe_pass@localhost:5432/recipe_db

POSTGRES_DB=recipe_db
POSTGRES_USER=recipe_user
POSTGRES_PASSWORD=recipe_pass
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────
APP_TITLE=Recipe Extractor & Meal Planner API
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─────────────────────────────────────────────────────────────
# CORS Origins (comma-separated, no spaces)
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Scraper Settings
# ─────────────────────────────────────────────────────────────
SCRAPER_MAX_TEXT_LENGTH=8000
SCRAPER_REQUEST_TIMEOUT=30
